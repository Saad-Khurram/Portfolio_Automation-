---
---

<section id="contact" class="bg-gray-900 text-white px-6 py-24 sm:px-12 lg:px-24">
  <div class="max-w-4xl mx-auto">

    <!-- Section header -->
    <div class="mb-16">
      <span class="text-emerald-400 text-sm font-mono font-medium tracking-widest uppercase">Contact</span>
      <h2 class="text-4xl sm:text-5xl font-bold mt-2">Let's work together.</h2>
      <p class="text-gray-400 mt-4 max-w-xl">If you have a process that still runs on copy-paste and prayer, let's talk. I've probably automated something like it already.</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Form -->
      <form
        action="https://formspree.io/f/mvgvedak"
        method="POST"
        class="space-y-5"
      >
        <div>
          <label for="name" class="block text-sm text-gray-400 mb-1.5">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            placeholder="Your name"
            class="w-full bg-gray-800 border border-gray-700 focus:border-emerald-500 focus:outline-none text-white placeholder-gray-600 rounded-lg px-4 py-3 text-sm transition-colors"
          />
        </div>
        <div>
          <label for="email" class="block text-sm text-gray-400 mb-1.5">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            class="w-full bg-gray-800 border border-gray-700 focus:border-emerald-500 focus:outline-none text-white placeholder-gray-600 rounded-lg px-4 py-3 text-sm transition-colors"
          />
        </div>
        <div>
          <label for="message" class="block text-sm text-gray-400 mb-1.5">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell me about the role or project..."
            class="w-full bg-gray-800 border border-gray-700 focus:border-emerald-500 focus:outline-none text-white placeholder-gray-600 rounded-lg px-4 py-3 text-sm transition-colors resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-semibold py-3 rounded-lg transition-colors duration-150"
        >
          Send message
        </button>
      </form>

      <!-- Links -->
      <div class="space-y-5">
        <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-6">Or reach me directly</p>

        <a
          href="mailto:saadkhurramkhan@gmail.com"
          class="flex items-center gap-4 p-4 border border-gray-800 hover:border-gray-600 rounded-xl transition-colors group"
        >
          <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-white">Email</p>
            <p class="text-sm text-gray-500">saadkhurramkhan@gmail.com</p>
          </div>
        </a>

        <a
          href="https://github.com/Saad-Khurram"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 border border-gray-800 hover:border-gray-600 rounded-xl transition-colors group"
        >
          <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-white">GitHub</p>
            <p class="text-sm text-gray-500">github.com/saadkhurram</p>
          </div>
        </a>

        <a
          href="https://www.linkedin.com/in/saad-khurram-baa2b1264"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 border border-gray-800 hover:border-gray-600 rounded-xl transition-colors group"
        >
          <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-white">LinkedIn</p>
            <p class="text-sm text-gray-500">linkedin.com/in/saad-khurram-baa2b1264</p>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-950 border-t border-gray-800 px-6 py-6 text-center text-sm text-gray-600">
  Built with Astro & Tailwind · Saad {new Date().getFullYear()}
</footer>
