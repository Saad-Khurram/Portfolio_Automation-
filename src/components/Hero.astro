---
---

<section class="min-h-screen text-white flex flex-col justify-center px-6 py-24 sm:px-12 lg:px-24 relative" style="background: radial-gradient(ellipse 70% 50% at 8% 30%, rgba(16,185,129,0.14) 0%, transparent 60%), radial-gradient(ellipse 50% 40% at 85% 85%, rgba(16,185,129,0.06) 0%, transparent 55%), #030712;">
  <div class="max-w-4xl mx-auto w-full">

    <!-- Availability badge -->
    <div class="flex w-fit items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs sm:text-sm font-medium px-4 py-1.5 rounded-full mb-8 max-w-full">
      <span class="w-2 h-2 shrink-0 bg-emerald-400 rounded-full animate-pulse"></span>
      <span>Open to Werkstudent roles · Berlin / Remote</span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight leading-tight mb-6">
      Still Learning.<br />
      <span class="text-emerald-400">Already Automating.</span>
    </h1>

    <!-- Sub-headline -->
    <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
      Bachelor's student in Berlin — building real workflows with <strong class="text-white">n8n</strong> and <strong class="text-white">Python</strong>, looking for a team where we can both grow.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 mb-16">
      <a
        href="#projects"
        class="bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-semibold px-6 py-3 rounded-lg transition-colors duration-150"
      >
        See my projects
      </a>
      <a
        href="https://github.com/Saad-Khurram"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 border-2 border-white/20 hover:border-white/50 text-gray-300 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-150"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub
      </a>
      <div class="relative" id="cv-dropdown">
        <button
          id="cv-btn"
          class="flex items-center gap-2 border-2 border-emerald-500/50 hover:border-emerald-400 text-emerald-400 hover:text-emerald-300 font-semibold px-6 py-3 rounded-lg transition-colors duration-150"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
          </svg>
          Download CV
          <svg class="w-3.5 h-3.5 ml-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="cv-menu" class="hidden absolute top-full left-0 mt-2 bg-gray-900 border border-gray-800 rounded-lg overflow-hidden z-20 shadow-xl min-w-full">
          <a href="/cv-en.pdf" download class="flex items-center gap-3 px-5 py-3 text-sm text-gray-200 hover:bg-gray-800 hover:text-white transition-colors duration-100">
            English
          </a>
          <a href="/cv-de.pdf" download class="flex items-center gap-3 px-5 py-3 text-sm text-gray-200 hover:bg-gray-800 hover:text-white transition-colors duration-100 border-t border-gray-800">
            Deutsch
          </a>
        </div>
      </div>
      <a
        href="#contact"
        class="border-2 border-white hover:bg-white text-white hover:text-gray-950 font-semibold px-6 py-3 rounded-lg transition-colors duration-150"
      >
        Get in touch
      </a>
    </div>

    <!-- Tech stack -->
    <div class="flex flex-wrap items-center gap-3">
      <span class="text-sm text-gray-300 mr-1">Stack:</span>
      {[
        'n8n',
        'OpenAI API',
        'Anthropic API',
        'SQL',
        'Python',
        'RAG',
        'REST APIs / Webhooks',
        'Make',
      ].map((tech) => (
        <span class="text-xs font-mono text-white bg-white/10 border border-white/30 px-3 py-1 rounded-md backdrop-blur-sm">
          {tech}
        </span>
      ))}
    </div>

  </div>
</section>

<script>
  const btn = document.getElementById('cv-btn');
  const menu = document.getElementById('cv-menu');
  const wrapper = document.getElementById('cv-dropdown');

  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  document.addEventListener('click', (e) => {
    if (!wrapper.contains(e.target as Node)) menu.classList.add('hidden');
  });
</script>
